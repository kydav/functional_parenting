rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Admins may write content. Keep this list in sync with kAdminEmails in
    // lib/core/providers/admin_provider.dart.
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email in [
          'ky.s.dav@gmail.com',
          'taylorthomascoaching@gmail.com'
        ];
    }

    // CMS-managed content: world-readable (public content), admin-only writes.
    match /tips/{doc}        { allow read: if true; allow write: if isAdmin(); }
    match /challenges/{doc}  { allow read: if true; allow write: if isAdmin(); }
    match /reflections/{doc} { allow read: if true; allow write: if isAdmin(); }
    match /scripts/{doc}     { allow read: if true; allow write: if isAdmin(); }

    // Workshops: public read, admin-only write. Reservations live in a
    // subcollection keyed by uid — a user can only create/delete their own, and
    // never touch the workshop doc. Admins can read the full attendee list.
    match /workshops/{workshopId} {
      allow read: if true;
      allow write: if isAdmin();

      match /reservations/{uid} {
        allow read: if isAdmin() ||
          (request.auth != null && request.auth.uid == uid);
        allow create, delete: if request.auth != null && request.auth.uid == uid;
        allow update: if false;
      }
    }

    // Per-user private data (streaks, saved reflections) — owner only.
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Default deny.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
